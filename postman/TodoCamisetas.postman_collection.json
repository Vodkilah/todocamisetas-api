          },
          "response": [
            { "name": "200 OK", "code": 200, "body": "{\n  \"mensaje\": \"Talla eliminada correctamente\"\n}" },
            { "name": "404 No encontrada", "code": 404, "body": "{\n  \"error\": \"Talla con id 99 no encontrada\"\n}" }
          ]
